# Server environment example. Copy to .env and fill values (DO NOT COMMIT .env).

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=supersecret
DB_NAME=goal_portal
# Or provide a single connection string (Render provides DATABASE_URL)
DATABASE_URL=postgres://user:pass@host:5432/dbname

# App
PORT=5000
NODE_ENV=production
JWT_SECRET=replace-with-secure-random
CLIENT_URL=https://app.example.com

# Email (one of these)
SENDGRID_API_KEY=SG.xxxxx
EMAIL_FROM=no-reply@example.com
# or SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=smtp-user
SMTP_PASS=smtp-pass

# Azure (optional for Azure AD SSO and tenant sync)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=https://your-server.example.com/auth/azure/callback
AZURE_MANAGER_GROUP_IDS=
AZURE_ADMIN_GROUP_IDS=

# Escalation
ESCALATION_HR_EMAILS=sajalkumardey71@gmail.com
ESCALATION_SWEEP_MINUTES=60

# Optional: protect cron endpoints called by Render cron jobs
CRON_SECRET=replace-with-random-token
